# ImageForge CLI — Environment Variables
# Copy this to .env or set system-wide for CI/CD usage

# ─── Provider API Keys ───────────────────────────────────────────────────────
IMAGEFORGE_OPENAI_API_KEY=sk-...
IMAGEFORGE_GEMINI_API_KEY=AIza...
IMAGEFORGE_STABILITY_API_KEY=sk-...
IMAGEFORGE_REPLICATE_API_KEY=r8_...
IMAGEFORGE_HUGGINGFACE_API_KEY=hf_...
IMAGEFORGE_FAL_API_KEY=...

# ─── OpenAI-Compatible (custom endpoint) ─────────────────────────────────────
IMAGEFORGE_OPENAI_COMPAT_BASE_URL=https://your-openai-compatible-api.com/v1
IMAGEFORGE_OPENAI_COMPAT_API_KEY=...

# ─── Defaults ────────────────────────────────────────────────────────────────
IMAGEFORGE_DEFAULT_PROVIDER=openai
IMAGEFORGE_DEFAULT_MODEL=dall-e-3
IMAGEFORGE_DEFAULT_SIZE=1024x1024
IMAGEFORGE_DEFAULT_QUALITY=standard
IMAGEFORGE_OUTPUT_DIR=./imageforge-output

# ─── Prompt Enhancement ──────────────────────────────────────────────────────
IMAGEFORGE_ENHANCE_PROMPTS=true
IMAGEFORGE_ENHANCE_PROVIDER=openai

# ─── Behavior ────────────────────────────────────────────────────────────────
IMAGEFORGE_JSON_OUTPUT=false
IMAGEFORGE_VERBOSE=false
IMAGEFORGE_NO_BANNER=false
